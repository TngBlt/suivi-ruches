# ========================================
# Suivi Ruches - Configuration
# ========================================
# NE PAS COMMITTER CE FICHIER AVEC LES VRAIS SECRETS!
# Copier en .env et ajouter les vraies valeurs

# API Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-example-key-replace-with-real

# Environment
NODE_ENV=production

# Serveur
PORT=3000
HOST=127.0.0.1

# Optionnel: Slack notifications
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optionnel: Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
NOTIFY_EMAIL=admin@example.com

# Optionnel: Monitoring
LOG_LEVEL=info
LOG_FILE=/var/log/suivi-ruches/app.log

# Optionnel: Database (si ajoutée plus tard)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=suivi_ruches
DB_USER=app_user
DB_PASSWORD=secure_password
